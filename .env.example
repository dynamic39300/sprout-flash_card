# flash_card 环境变量示例
# 复制为 .env 并按需修改。.env 不入库（见 .gitignore）。
# 严禁在此文件填入真实密钥；本文件仅作占位与说明。
#
# 生产环境快速配置（ECS 上）：
#   NODE_ENV=production
#   PORT=8787
#   TZ=Asia/Shanghai
#   DATA_DIR=/home/ubuntu/flash_card/data
#   DB_FILE=/home/ubuntu/flash_card/data/flash_card.db
#   UPLOAD_DIR=/home/ubuntu/flash_card/data/uploads
#   MAX_UPLOAD_MB=5

# 运行环境：development | production
NODE_ENV=development

# 后端服务监听端口（默认 8787，避开常见占用的 3000）
PORT=8787

# 时区：影响"按天"归日的复习/打卡统计（务必与部署地一致，避免跨天边界偏差）
TZ=Asia/Shanghai

# SQLite 数据库文件路径（目录不入库，需单独备份）
DATA_DIR=./data
DB_FILE=./data/flash_card.db

# 图片上传存储目录（不入库，需单独备份）
UPLOAD_DIR=./data/uploads

# 单张图片上传大小上限（MB）
MAX_UPLOAD_MB=5

# 允许上传的图片 MIME 类型（逗号分隔）
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp,image/gif

# 【预留】访问密码：留空表示免登录（当前 MVP 默认）。
# 设置后，前端需携带该口令方可访问，用于公网部署时的最小防护。
# ACCESS_PASSWORD=

# 【预留·未来迁移 OSS 时启用】阿里云 OSS 配置（当前用本地磁盘，无需填写）
# OSS_REGION=
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
